# ============================================
# What A Service — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values.

# --- Contact Form (Resend) ---
# Sign up at https://resend.com and create an API key.
# Free tier: 100 emails/day, 3000/month.
RESEND_API_KEY=re_xxxxxxxxxx
CONTACT_EMAIL=contact@whataservice.fr

# --- HubSpot CRM ---
# Private App token — create at Settings > Integrations > Private Apps.
# Required scopes: crm.objects.contacts.write, crm.objects.contacts.read, crm.schemas.contacts.read
HUBSPOT_ACCESS_TOKEN=pat-xxx-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Analytics (optional) ---
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
